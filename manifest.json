{
  "manifest_version": 3,

  "name": "QuickMark",

  "version": "3.1.0",

  "description": "极简收藏启动器",

  "permissions": [
    "bookmarks",
    "storage",
    "tabs"
  ],

  "action": {

    "default_popup": "popup.html",

    "default_title": "QuickMark",

    "default_icon": {

      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },

  "icons": {

    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}